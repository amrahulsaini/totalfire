{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Flutter Chrome No Security",
			"type": "shell",
			"command": "C:\\Users\\ammra\\flutter\\flutter\\bin\\flutter.bat",
			"args": [
				"run",
				"-d",
				"chrome",
				"--web-browser-flag=--disable-web-security",
